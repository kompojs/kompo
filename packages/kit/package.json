{
  "name": "@kompojs/kit",
  "version": "0.1.0",
  "description": "Shared interfaces and utilities for Kompo CLI plugins",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c ../vitest.config.ts --passWithNoTests",
    "test:coverage": "vitest run -c ../vitest.config.ts --coverage --passWithNoTests",
    "clean": "rimraf .turbo node_modules dist build .next coverage tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@kompojs/config": "workspace:*",
    "eta": "^3.2.0",
    "semver": "^7.6.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.3.0"
  }
}
