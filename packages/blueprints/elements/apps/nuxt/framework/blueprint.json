{
  "name": "nuxt",
  "type": "app",
  "env": {
    "NUXT_PUBLIC_APP_NAME": {
      "validation": "z.string()",
      "default": "{{projectName}}",
      "side": "client"
    },
    "NUXT_PUBLIC_HELLO_WORLD": {
      "validation": "z.string()",
      "default": "It Works!",
      "side": "client"
    },
    "NUXT_RUNTIME": {
      "validation": "z.enum(['nodejs', 'edge']).optional()",
      "side": "server"
    }
  },
  "id": "nuxt"
}
