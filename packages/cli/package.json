{
  "name": "@kompojs/cli",
  "version": "0.1.6",
  "description": "Kompo CLI - Web3 Component as a Service",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kompo": "./dist/bin/kompo.js"
  },
  "exports": {
    "./bin": "./dist/bin/kompo.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c ../vitest.config.ts --passWithNoTests",
    "test:coverage": "vitest run -c ../vitest.config.ts --coverage --passWithNoTests",
    "kompo": "tsx src/bin/kompo.ts",
    "clean": "rimraf .turbo node_modules dist build .next coverage"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.9",
    "@kompojs/blueprints": "^0.1.2",
    "@kompojs/config": "workspace:*",
    "@kompojs/kit": "workspace:*",
    "cfonts": "^3.3.1",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "eta": "^3.2.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "@kompojs/ai": "0.0.1-beta.1",
    "openai": "^6.15.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.29",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.6.2",
    "vitest": "^3.2.4"
  }
}
